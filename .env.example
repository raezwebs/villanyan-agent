# Villanyan-Agent 3.0 — .env
VILLANYAN_PASSWORD=
SECRET_KEY=
DATABASE_URL=sqlite+aiosqlite:///./villanyan-agent.db
VILLANYAN_PORT=7890
DEBUG=true
ALLOWED_ORIGINS=*
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12
GEMINI_API_KEY=
OPENAI_API_KEY=
OLLAMA_API_URL=http://192.168.1.109:11434
OLLAMA_MODEL=deepseek-r1:1.5b

# DeepSeek API — PRIMARY LLM (https://api-docs.deepseek.com/)
# Modele: deepseek-v4-flash (szybki), deepseek-v4-pro (dokładny)
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-v4-flash
